@model IEnumerable<universidad.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1 class="text-center">Courses</h1>

<p class="d-flex flex-row-reverse">
    <a asp-action="Create" class="btn btn-dark">Create New</a>
</p>
<div class="d-flex gap-2 flex-wrap align-items-center">

@foreach (var item in Model) {
        <div class="card text-center" style="width:18rem;">
            <div class="card-header">

            <span class="text-primary lead fw-bolder">
                @Html.DisplayFor(modelItem => item.Name)
            </span>
            </div>
            <div class="card-body">
            <p>
                Code: @Html.DisplayFor(modelItem => item.Code)
            </p>

            <p>
                Credits: @Html.DisplayFor(modelItem => item.Credits)
            </p>
            <div >
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary">
                    
                    <i class="bi bi-pencil-square"></i>
                    </a> 
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning">
                    <i class="bi bi-eye"></i>
                </a> 
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">
                    <i class="bi bi-trash"></i>
                </a>
            </div>
            </div>
        </div>
}
</div>